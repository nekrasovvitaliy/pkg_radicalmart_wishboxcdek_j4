<?xml version="1.0" encoding="utf-8"?>
<extension version="3.8.1" type="plugin" method="upgrade" group="system">
	<name>plg_radicalmart_wishboxcdek</name>
	<creationDate>December 2023</creationDate>
	<version>1.0.0</version>
	<author>Vitaliy Nekrasov</author>
	<authorEmail>nekrasov_vitaliy@list.ru</authorEmail>
	<copyright>Copyright (C) 2013–2023 WishBox. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later</license>
	<description>PLG_RADICALMART_WISHBOXCDEK_XML_DESCRIPTION</description>
	<namespace path="src">Joomla\Plugin\Radicalmart\Wishboxcdek</namespace>
	<files>
		<folder plugin="wishboxcdek">services</folder>
		<folder>src</folder>
	</files>
	<languages>
		<language tag="en-GB">language/en-GB/plg_radicalmart_wishboxcdek.ini</language>
		<language tag="en-GB">language/en-GB/plg_radicalmart_wishboxcdek.sys.ini</language>
		<language tag="ru-RU">language/ru-RU/plg_radicalmart_wishboxcdek.ini</language>
		<language tag="ru-RU">language/ru-RU/plg_radicalmart_wishboxcdek.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
						name="api_account"
						type="textarea"
						label="PLG_RADICALMART_WISHBOXCDEK_FIELD_API_ACCOUNT_LABEL"
						default=""
				/>
				<field
						name="api_secure"
						type="textarea"
						label="PLG_RADICALMART_WISHBOXCDEK_FIELD_API_SECURE_LABEL"
						default=""
				/>

				<field
						name="order_type"
						type="list"
						label="PLG_RADICALMART_WISHBOXCDEK_FIELD_ORDER_TYPE_LABEL"
						default=""
						filter="integer"
						class="form-select-color"
				>
					<option value="1">PLG_RADICALMART_WISHBOXCDEK_FIELD_ORDER_TYPE_SHOP_LABEL</option>
					<option value="2">PLG_RADICALMART_WISHBOXCDEK_FIELD_ORDER_TYPE_SHIPPING_LABEL</option>
				</field>

				type
			</fieldset>
		</fields>
	</config>
</extension>