<?xml version="1.0" encoding="utf-8"?>
<config>
    <fieldset
			label="COM_WISHBOXRADICALMARTCDEK"
			name="wishboxcdek"
			addfieldprefix="Joomla\Component\Wishboxradicalmartcdek\Administrator\Field"
	>
		<field
				name="debug_mode"
				type="radio"
				label="COM_WISHBOXRADICALMARTCDEK_FIELD_DEBUG_MODE_LABEL"
				default="0"
				layout="joomla.form.field.radio.switcher"
		>
			<option value="0">JNO</option>
			<option value="1">JYES</option>
		</field>
		<field name="ready_status_id"
			   type="Statuses"
			   label="COM_WISHBOXRADICALMARTCDEK_FIELD_READY_STATUS_LABEL"
			   addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field"
		/>
		<field name="error_status_id"
			   type="Statuses"
			   label="COM_WISHBOXRADICALMARTCDEK_FIELD_ERROR_STATUS_LABEL"
			   addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field"
		/>
		<field name="completed_status_id"
			   type="Statuses"
			   label="COM_WISHBOXRADICALMARTCDEK_FIELD_COMPLETED_STATUS_LABEL"
			   addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field"
		/>
		<field name="order_number_prefix"
			   type="text"
			   label="COM_WISHBOXRADICALMARTCDEK_FIELD_ORDER_NUMBER_PREFIX_LABEL"
		/>
    </fieldset>

    <fieldset name="permissions" description="JCONFIG_PERMISSIONS_DESC" label="JCONFIG_PERMISSIONS_LABEL">
        <field
			name="rules"
			type="rules"
			component="com_wishboxradicalmartcdek"
			class="inputbox"
			filter="rules"
			validate="rules"
			label="JCONFIG_PERMISSIONS_LABEL"
			section="component"
		/>
	</fieldset>
</config>